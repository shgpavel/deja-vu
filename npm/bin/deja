#!/usr/bin/env node

const { spawnSync } = require('node:child_process');
const path = require('node:path');

const arch = process.arch === 'x64' ? 'amd64' : process.arch;
const platform = process.platform === 'win32' ? 'windows' : process.platform;
const pkg = `@vshulcz/deja-vu-${platform}-${arch}`;
const exe = platform === 'windows' ? 'deja.exe' : 'deja';

let bin;
try {
  bin = require.resolve(path.join(pkg, 'bin', exe));
} catch (err) {
  console.error(`deja: missing optional binary package ${pkg}`);
  console.error('deja: TODO publish the platform package, or install via: go install github.com/vshulcz/deja-vu/cmd/deja@latest');
  process.exit(1);
}

const result = spawnSync(bin, process.argv.slice(2), { stdio: 'inherit' });
if (result.error) {
  console.error(result.error.message);
  process.exit(1);
}
process.exit(result.status ?? 0);
